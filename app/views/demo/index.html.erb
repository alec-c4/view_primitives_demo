          <%= ui "skeleton", class: "h-4 w-3/4" %>
        </div>
      </div>

      <div class="max-w-sm space-y-2">
        <%= ui "skeleton", class: "h-40 w-full rounded-xl" %>
        <%= ui "skeleton", class: "h-4 w-full" %>
        <%= ui "skeleton", class: "h-4 w-2/3" %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# PROGRESS %>
    <%# ------------------------------------------------------------------ %>
