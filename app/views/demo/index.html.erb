              heading: "Settings",
              items: [
                { title: "Team",    href: "#", description: "Invite and manage users." },
                { title: "Billing", href: "#", description: "Plans and invoices." }
              ]) %>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# DIALOG %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Dialog</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">With title, description and footer</h3>
        <%= ui :dialog, title: "Edit profile", description: "Make changes to your profile here. Click save when you're done." do |d| %>
          <% d.with_trigger do %>
            <%= ui :button, "Edit Profile", variant: :outline %>
          <% end %>
          <div class="space-y-3 py-2">
            <%= ui :form_field, label: "Name", hint: "Your display name" do %>
              <%= ui :input, placeholder: "Jane Doe" %>
            <% end %>
            <%= ui :form_field, label: "Username" do %>
              <%= ui :input, placeholder: "@janedoe" %>
            <% end %>
          </div>
          <% d.with_footer do %>
            <%= ui :button, "Cancel", variant: :outline, data: { action: "click->dialog#close" } %>
            <%= ui :button, "Save changes" %>
          <% end %>
        <% end %>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Simple message</h3>
        <%= ui :dialog, title: "Heads up!", description: "You can add components to your app using the CLI." do |d| %>
          <% d.with_trigger do %>
            <%= ui :button, "Show Dialog" %>
          <% end %>
          <% d.with_footer do %>
            <%= ui :button, "Got it", data: { action: "click->dialog#close" } %>
          <% end %>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# ALERT DIALOG %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Alert Dialog</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Destructive confirmation</h3>
        <%= ui :alert_dialog,
              title: "Are you absolutely sure?",
              description: "This action cannot be undone. This will permanently delete your account and remove your data from our servers." do |d| %>
          <% d.with_trigger do %>
            <%= ui :button, "Delete Account", variant: :destructive %>
          <% end %>
          <% d.with_footer do %>
            <%= ui :button, "Cancel", variant: :outline, data: { action: "click->dialog#close" } %>
            <%= ui :button, "Yes, delete account", variant: :destructive, data: { action: "click->dialog#close" } %>
          <% end %>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# SHEET %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Sheet</h2>

      <div class="flex flex-wrap gap-3">
        <% %i[right left top bottom].each do |side| %>
          <%= ui :sheet, title: "Sheet (#{side})", description: "A slide-in panel from the #{side}.", side: side do |s| %>
            <% s.with_trigger do %>
              <%= ui :button, side.to_s.capitalize, variant: :outline %>
            <% end %>
            <p class="text-sm text-muted-foreground">Place any content here — forms, settings, details.</p>
            <% s.with_footer do %>
              <%= ui :button, "Close", variant: :outline, data: { action: "click->sheet#close" } %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# DRAWER %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Drawer</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Bottom sheet (mobile drawer)</h3>
        <%= ui :drawer, title: "Move to project", description: "Pick a project to move this task into." do |d| %>
          <% d.with_trigger do %>
            <%= ui :button, "Open Drawer" %>
          <% end %>
          <div class="space-y-2">
            <% ["Design system", "Backend API", "Marketing site"].each do |project| %>
              <button class="w-full rounded-md border px-4 py-3 text-left text-sm hover:bg-accent transition-colors">
                <%= project %>
              </button>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# POPOVER %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Popover</h2>

      <div class="flex flex-wrap gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Below (default)</h3>
          <%= ui :popover do |p| %>
            <% p.with_trigger do %>
              <%= ui :button, "Open Popover", variant: :outline %>
            <% end %>
            <div class="space-y-2">
              <p class="font-medium text-sm">Dimensions</p>
              <%= ui :form_field, label: "Width" do %>
                <%= ui :input, placeholder: "100%" %>
              <% end %>
              <%= ui :form_field, label: "Height" do %>
                <%= ui :input, placeholder: "auto" %>
              <% end %>
            </div>
          <% end %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Above</h3>
          <%= ui :popover, side: :top do |p| %>
            <% p.with_trigger do %>
              <%= ui :button, "Popover above", variant: :outline %>
            <% end %>
            <p class="text-sm">This popover appears above the trigger.</p>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# TOOLTIP %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Tooltip</h2>

      <div class="flex flex-wrap gap-6 items-end">
        <% [[:top, "Top"], [:bottom, "Bottom"], [:left, "Left"], [:right, "Right"]].each do |side, label| %>
          <div>
            <h3 class="text-sm font-medium text-muted-foreground mb-3"><%= label %></h3>
            <%= ui :tooltip, text: "#{label} tooltip", side: side do %>
              <%= ui :button, label, variant: :outline %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# HOVER CARD %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Hover Card</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">User preview</h3>
        <%= ui :hover_card do |h| %>
          <% h.with_trigger do %>
            <a href="#" class="text-sm font-medium underline underline-offset-4 hover:no-underline">@alexey</a>
          <% end %>
          <div class="flex items-start gap-3">
            <%= ui :avatar, initials: "AP", class: "size-10" %>
            <div class="space-y-1">
              <p class="text-sm font-semibold">Alexey Poimtsev</p>
              <p class="text-xs text-muted-foreground">@alexey · Joined May 2020</p>
              <p class="text-xs text-muted-foreground mt-1">Building ViewPrimitives — shadcn/ui for Rails.</p>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# DROPDOWN MENU %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Dropdown Menu</h2>

      <div class="flex flex-wrap gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Default (align start)</h3>
          <%= ui :dropdown_menu do |d| %>
            <% d.with_trigger do %>
              <%= ui :button, "Options", variant: :outline %>
            <% end %>
            <button class="<%= UI::DropdownMenuComponent::ITEM %>">Edit</button>
            <button class="<%= UI::DropdownMenuComponent::ITEM %>">Duplicate</button>
            <hr class="<%= UI::DropdownMenuComponent::SEPARATOR %>">
            <button class="<%= UI::DropdownMenuComponent::ITEM %>">Archive</button>
            <button class="<%= UI::DropdownMenuComponent::ITEM %>">Delete</button>
          <% end %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Align end</h3>
          <%= ui :dropdown_menu, align: :end do |d| %>
            <% d.with_trigger do %>
              <%= ui :button, "My Account", variant: :outline %>
            <% end %>
            <span class="<%= UI::DropdownMenuComponent::LABEL_CLS %>">my@email.com</span>
            <hr class="<%= UI::DropdownMenuComponent::SEPARATOR %>">
            <button class="<%= UI::DropdownMenuComponent::ITEM %>">Profile</button>
            <button class="<%= UI::DropdownMenuComponent::ITEM %>">Settings</button>
            <hr class="<%= UI::DropdownMenuComponent::SEPARATOR %>">
            <button class="<%= UI::DropdownMenuComponent::ITEM %>">Log out</button>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# CONTEXT MENU %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Context Menu</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Right-click the area below</h3>
        <%= ui :context_menu, class: "rounded-lg border-2 border-dashed border-muted p-12 text-center text-sm text-muted-foreground cursor-default" do |c| %>
          <% c.with_menu do %>
            <button class="<%= UI::DropdownMenuComponent::ITEM %>">Back</button>
            <button class="<%= UI::DropdownMenuComponent::ITEM %>">Forward</button>
            <button class="<%= UI::DropdownMenuComponent::ITEM %>">Reload</button>
            <hr class="<%= UI::DropdownMenuComponent::SEPARATOR %>">
            <button class="<%= UI::DropdownMenuComponent::ITEM %>">Save as...</button>
            <button class="<%= UI::DropdownMenuComponent::ITEM %>">View Page Source</button>
          <% end %>
          Right-click here to open context menu
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# MENUBAR %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Menubar</h2>

      <%= ui :menubar do |m| %>
        <% m.with_menu(label: "File") do %>
          <span class="<%= UI::DropdownMenuComponent::LABEL_CLS %>">New</span>
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">New Tab</button>
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">New Window</button>
          <hr class="<%= UI::DropdownMenuComponent::SEPARATOR %>">
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Open...</button>
          <hr class="<%= UI::DropdownMenuComponent::SEPARATOR %>">
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Save</button>
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Save As...</button>
        <% end %>
        <% m.with_menu(label: "Edit") do %>
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Undo</button>
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Redo</button>
          <hr class="<%= UI::DropdownMenuComponent::SEPARATOR %>">
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Cut</button>
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Copy</button>
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Paste</button>
        <% end %>
        <% m.with_menu(label: "View") do %>
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Always Show Bookmarks Bar</button>
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Always Show Full URLs</button>
          <hr class="<%= UI::DropdownMenuComponent::SEPARATOR %>">
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Reload</button>
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Full Screen</button>
        <% end %>
        <% m.with_menu(label: "Help") do %>
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Search Menu</button>
          <hr class="<%= UI::DropdownMenuComponent::SEPARATOR %>">
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">Keyboard Shortcuts</button>
          <button class="<%= UI::DropdownMenuComponent::ITEM %>">About</button>
        <% end %>
      <% end %>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# COMMAND %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Command</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Command palette — click or press ⌘K</h3>
        <%= ui :command do |c| %>
          <% c.with_trigger do %>
            <button type="button" class="inline-flex h-9 w-64 items-center gap-2 rounded-md border bg-muted/50 px-3 text-sm text-muted-foreground shadow-none hover:bg-accent hover:text-accent-foreground">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              <span class="flex-1 text-left">Search commands...</span>
              <kbd class="pointer-events-none hidden h-5 select-none items-center gap-1 rounded border bg-muted px-1.5 font-mono text-[10px] font-medium opacity-100 sm:flex">
                <span class="text-xs">⌘</span>K
              </kbd>
            </button>
          <% end %>
          <div class="<%= UI::CommandComponent::GROUP_WRAPPER %>" data-command-group>
            <p class="<%= UI::CommandComponent::GROUP %>">Suggestions</p>
            <button class="<%= UI::CommandComponent::ITEM %>" data-command-value="calendar">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              <span>Calendar</span>
            </button>
            <button class="<%= UI::CommandComponent::ITEM %>" data-command-value="search emoji">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" x2="9.01" y1="9" y2="9"/><line x1="15" x2="15.01" y1="9" y2="9"/></svg>
              <span>Search Emoji</span>
            </button>
            <button class="<%= UI::CommandComponent::ITEM %>" data-command-value="calculator">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="16" x2="16" y1="14" y2="18"/><path d="M8 14h.01M12 14h.01M8 18h.01M12 18h.01"/></svg>
              <span>Calculator</span>
            </button>
          </div>
          <hr class="<%= UI::CommandComponent::SEPARATOR %>">
          <div class="<%= UI::CommandComponent::GROUP_WRAPPER %>" data-command-group>
            <p class="<%= UI::CommandComponent::GROUP %>">Settings</p>
            <button class="<%= UI::CommandComponent::ITEM %>" data-command-value="profile settings">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>Profile</span>
              <span class="<%= UI::CommandComponent::SHORTCUT %>">⌘P</span>
            </button>
            <button class="<%= UI::CommandComponent::ITEM %>" data-command-value="billing payment">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
              <span>Billing</span>
              <span class="<%= UI::CommandComponent::SHORTCUT %>">⌘B</span>
            </button>
            <button class="<%= UI::CommandComponent::ITEM %>" data-command-value="settings configuration">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
              <span>Settings</span>
              <span class="<%= UI::CommandComponent::SHORTCUT %>">⌘S</span>
            </button>
          </div>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# COMBOBOX %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Combobox</h2>

      <div class="flex flex-wrap gap-6">
        <div class="w-64">
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Framework</h3>
          <%= ui :combobox, name: "framework", placeholder: "Select framework...", options: [
            { value: "rails",   label: "Ruby on Rails" },
            { value: "next",    label: "Next.js" },
            { value: "nuxt",    label: "Nuxt" },
            { value: "laravel", label: "Laravel" },
            { value: "django",  label: "Django" },
          ] %>
        </div>

        <div class="w-64">
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Country (pre-selected)</h3>
          <%= ui :combobox, name: "country", value: "ca", placeholder: "Select country...", options: [
            { value: "us", label: "United States" },
            { value: "ca", label: "Canada" },
            { value: "gb", label: "United Kingdom" },
            { value: "de", label: "Germany" },
            { value: "fr", label: "France" },
            { value: "jp", label: "Japan" },
          ] %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# COLLAPSIBLE %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Collapsible</h2>

      <div class="flex flex-wrap items-start gap-6">
        <div class="w-80">
          <%= ui :collapsible do |c| %>
            <% c.with_trigger do %>
              <span class="font-medium text-sm">What is ViewPrimitives?</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-muted-foreground transition-transform [[open]_&]:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
            <% end %>
            <p class="text-sm text-muted-foreground mt-2">
              A library of copy-paste UI components for Rails built with ViewComponent and Tailwind.
            </p>
          <% end %>
        </div>

        <div class="w-80">
          <%= ui :collapsible do |c| %>
            <% c.with_trigger do %>
              <span class="font-medium text-sm">Do I need JavaScript?</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-muted-foreground transition-transform [[open]_&]:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
            <% end %>
            <p class="text-sm text-muted-foreground mt-2">
              No — this Collapsible uses a native <code>&lt;details&gt;</code> element with no JS required.
            </p>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# SCROLL AREA %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Scroll Area</h2>

      <div class="flex flex-wrap gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Vertical (200px)</h3>
          <%= ui :scroll_area, class: "h-48 w-64 rounded-md border border-border p-4" do %>
            <% 20.times do |i| %>
              <p class="text-sm py-1">Item <%= i + 1 %></p>
            <% end %>
          <% end %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Horizontal</h3>
          <%= ui :scroll_area, orientation: :horizontal, class: "w-64 rounded-md border border-border p-4" do %>
            <div class="flex gap-4" style="width: 600px">
              <% 8.times do |i| %>
                <div class="w-24 shrink-0 rounded-md bg-muted p-3 text-sm text-center">Card <%= i + 1 %></div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# CHAT BUBBLE %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Chat Bubble</h2>

      <div class="w-96 space-y-4">
        <%= ui :chat_bubble, sent: false, timestamp: "9:41 AM" do %>
          Hey! Have you tried ViewPrimitives yet?
        <% end %>

        <%= ui :chat_bubble, sent: true, timestamp: "9:42 AM" do %>
          Yes, it's amazing! Copy-paste components for Rails.
        <% end %>

        <%= ui :chat_bubble, sent: false, timestamp: "9:43 AM" do %>
          Totally agree. No npm, just Tailwind + ViewComponent.
        <% end %>

        <%= ui :chat_bubble, sent: true, timestamp: "9:43 AM" do %>
          And Stimulus for the interactive bits!
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# CALENDAR %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Calendar</h2>

      <div class="flex flex-wrap gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Basic</h3>
          <%= ui :calendar %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Pre-selected date</h3>
          <%= ui :calendar, selected: Date.today, name: "date" %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">With min/max bounds</h3>
          <%= ui :calendar, min: Date.today - 7, max: Date.today + 14 %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# DATE PICKER %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Date Picker</h2>

      <div class="flex flex-wrap gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Default</h3>
          <%= ui :date_picker, name: "start_date" %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Pre-filled</h3>
          <%= ui :date_picker, value: Date.today, name: "end_date" %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Custom placeholder</h3>
          <%= ui :date_picker, placeholder: "Choose deadline…", name: "deadline" %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# TIMEPICKER %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Timepicker</h2>

      <div class="flex flex-wrap gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">24-hour</h3>
          <%= ui :timepicker, name: "start_time" %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">12-hour (AM/PM)</h3>
          <%= ui :timepicker, format: :h12, name: "meeting_time" %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">30-minute steps</h3>
          <%= ui :timepicker, step: 30, value: "09:00", name: "slot" %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# INPUT OTP %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Input OTP</h2>

      <div class="flex flex-wrap gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">6 digits (default)</h3>
          <%= ui :input_otp, name: "otp" %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">4 digits</h3>
          <%= ui :input_otp, length: 4, name: "pin" %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">With separator</h3>
          <%= ui :input_otp, length: 6, separator: 3, name: "code" %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# CAROUSEL %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Carousel</h2>

      <div class="flex flex-wrap gap-6">
        <div class="w-80">
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Basic</h3>
          <%= ui :carousel do |c| %>
            <% ["Slide 1", "Slide 2", "Slide 3"].each do |label| %>
              <% c.with_slide do %>
                <div class="flex h-48 items-center justify-center rounded-lg bg-muted text-lg font-medium">
                  <%= label %>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>

        <div class="w-80">
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Autoplay (3s)</h3>
          <%= ui :carousel, autoplay: 3000 do |c| %>
            <% [["bg-primary/20", "A"], ["bg-secondary/40", "B"], ["bg-accent/60", "C"]].each do |bg, label| %>
              <% c.with_slide do %>
                <div class="flex h-48 items-center justify-center rounded-lg text-2xl font-bold <%= bg %>">
                  <%= label %>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# GALLERY %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Gallery</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">3-column grid with lightbox</h3>
        <%= ui :gallery, cols: 3 do |g| %>
          <% [
            { src: "https://picsum.photos/seed/a/400/300", alt: "Mountain lake" },
            { src: "https://picsum.photos/seed/b/400/300", alt: "Forest path" },
            { src: "https://picsum.photos/seed/c/400/300", alt: "City skyline" },
            { src: "https://picsum.photos/seed/d/400/300", alt: "Desert dunes" },
            { src: "https://picsum.photos/seed/e/400/300", alt: "Ocean waves" },
            { src: "https://picsum.photos/seed/f/400/300", alt: "Snowy peaks" },
          ].each do |img| %>
            <% g.with_image(src: img[:src], alt: img[:alt]) %>
          <% end %>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# SPEED DIAL %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Speed Dial</h2>

      <h3 class="text-sm font-medium text-muted-foreground">Bottom right</h3>
      <div class="relative h-48 rounded-lg border border-border bg-muted/20">
        <%= ui :speed_dial, style: "position: absolute; bottom: 24px; right: 24px;" do |d| %>
          <% d.with_action(label: "New document", href: "#") %>
          <% d.with_action(label: "Upload file",  href: "#") %>
          <% d.with_action(label: "Share link",   href: "#") %>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# RESIZABLE %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Resizable</h2>

      <div class="space-y-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Horizontal (drag the divider)</h3>
          <%= ui :resizable, class: "h-40" do |r| %>
            <% r.with_panel(default: 35) do %>
              <div class="flex h-full items-center justify-center p-4 text-sm text-muted-foreground">
                Left panel
              </div>
            <% end %>
            <% r.with_panel do %>
              <div class="flex h-full items-center justify-center p-4 text-sm text-muted-foreground">
                Right panel
              </div>
            <% end %>
          <% end %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Vertical</h3>
          <%= ui :resizable, direction: :vertical, class: "h-56" do |r| %>
            <% r.with_panel(default: 40) do %>
              <div class="flex h-full items-center justify-center p-4 text-sm text-muted-foreground">
                Top panel
              </div>
            <% end %>
            <% r.with_panel do %>
              <div class="flex h-full items-center justify-center p-4 text-sm text-muted-foreground">
                Bottom panel
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# SIDEBAR %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Sidebar</h2>

      <div class="relative h-80 overflow-hidden rounded-lg border border-border bg-background">
        <%= ui :sidebar, brand: "Acme",
          style: "position: relative; inset: auto; z-index: 1;" do |s| %>
          <% s.with_group(label: "Main") do |g| %>
            <% g.with_item(label: "Dashboard", href: "#", icon: :dashboard, active: true) %>
            <% g.with_item(label: "Projects",  href: "#", icon: :folder) %>
            <% g.with_item(label: "Tasks",     href: "#", icon: :tasks) %>
          <% end %>
          <% s.with_group(label: "Account") do |g| %>
            <% g.with_item(label: "Settings", href: "#", icon: :settings) %>
            <% g.with_item(label: "Billing",  href: "#", icon: :credit_card) %>
          <% end %>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# DATA TABLE %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Data Table</h2>

      <%= ui :data_table,
        columns: [
          { key: :name,       label: "Name",       sortable: true },
          { key: :role,       label: "Role",        sortable: true },
          { key: :status,     label: "Status",      sortable: true },
          { key: :joined,     label: "Joined",      sortable: true },
        ],
        rows: [
          { name: "Alice Chen",    role: "Engineer",   status: "Active",    joined: "2022-03-14" },
          { name: "Bob Smith",     role: "Designer",   status: "Active",    joined: "2021-11-02" },
          { name: "Carol White",   role: "PM",         status: "On leave",  joined: "2020-06-28" },
          { name: "David Park",    role: "Engineer",   status: "Active",    joined: "2023-01-09" },
          { name: "Eva Martinez",  role: "QA",         status: "Inactive",  joined: "2019-08-17" },
          { name: "Frank Liu",     role: "Engineer",   status: "Active",    joined: "2022-09-30" },
          { name: "Grace Kim",     role: "Designer",   status: "Active",    joined: "2023-04-05" },
          { name: "Hank Torres",   role: "DevOps",     status: "Active",    joined: "2021-07-22" },
          { name: "Iris Johnson",  role: "PM",         status: "Active",    joined: "2020-12-11" },
          { name: "Jack Brown",    role: "Engineer",   status: "On leave",  joined: "2022-05-19" },
          { name: "Karen Lee",     role: "QA",         status: "Active",    joined: "2023-08-03" },
          { name: "Leo Adams",     role: "Engineer",   status: "Inactive",  joined: "2018-03-27" },
        ],
        per_page: 5,
        caption: "Team members" %>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# TOASTER %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Toaster</h2>

      <div class="space-y-3">
        <p class="text-sm text-muted-foreground">Click a button to trigger a toast. The toaster container is fixed bottom-right on this page.</p>
        <div class="flex flex-wrap gap-2">
          <button type="button"
            class="inline-flex h-9 items-center rounded-md border border-input bg-background px-3 text-sm font-medium hover:bg-accent transition"
            onclick="window.dispatchEvent(new CustomEvent('toaster:add', { detail: { message: 'Changes saved successfully.' } }))">
            Default
          </button>
          <button type="button"
            class="inline-flex h-9 items-center rounded-md border border-input bg-background px-3 text-sm font-medium hover:bg-accent transition"
            onclick="window.dispatchEvent(new CustomEvent('toaster:add', { detail: { message: 'Profile updated.', variant: 'success' } }))">
            Success
          </button>
          <button type="button"
            class="inline-flex h-9 items-center rounded-md border border-input bg-background px-3 text-sm font-medium hover:bg-accent transition"
            onclick="window.dispatchEvent(new CustomEvent('toaster:add', { detail: { title: 'Warning', message: 'Session expires in 5 minutes.', variant: 'warning' } }))">
            Warning
          </button>
          <button type="button"
            class="inline-flex h-9 items-center rounded-md border border-input bg-background px-3 text-sm font-medium hover:bg-accent transition"
            onclick="window.dispatchEvent(new CustomEvent('toaster:add', { detail: { title: 'Error', message: 'Failed to save changes.', variant: 'destructive' } }))">
            Destructive
          </button>
          <button type="button"
            class="inline-flex h-9 items-center rounded-md border border-input bg-background px-3 text-sm font-medium hover:bg-accent transition"
            onclick="window.dispatchEvent(new CustomEvent('toaster:add', { detail: { message: 'New version available.', variant: 'info', duration: 0 } }))">
            Info (no auto-dismiss)
          </button>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# TIMELINE %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Timeline</h2>

      <div class="flex flex-wrap gap-12">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-4">Default</h3>
          <%= ui :timeline do |t| %>
            <% t.with_item(date: "January 2025", title: "Project kicked off") %>
            <% t.with_item(date: "February 2025", title: "Design complete", description: "Wireframes and visual specs approved by stakeholders") %>
            <% t.with_item(date: "March 2025", title: "Development started") %>
            <% t.with_item(date: "April 2025", title: "Beta released", description: "Shipped to internal testers") %>
          <% end %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-4">With variants</h3>
          <%= ui :timeline do |t| %>
            <% t.with_item(date: "2025-01-10", title: "Deployment triggered", variant: :default) %>
            <% t.with_item(date: "2025-01-10", title: "Health checks passed", description: "All 12 instances healthy", variant: :success) %>
            <% t.with_item(date: "2025-01-10", title: "High memory usage", description: "p99 spiked to 87%", variant: :warning) %>
            <% t.with_item(date: "2025-01-11", title: "Rollback initiated", variant: :destructive) %>
            <% t.with_item(date: "2025-01-11", title: "Resolved — patch deployed", variant: :success) %>
          <% end %>
        </div>
      </div>
    </section>

    <%# CHART %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Chart</h2>
      <p class="text-sm text-muted-foreground">Chart.js adapter — requires <code class="font-mono text-xs bg-muted px-1 py-0.5 rounded">chart.js</code> pinned in importmap.</p>

      <div class="flex flex-wrap gap-8">
        <div class="w-96">
          <h3 class="text-sm font-medium text-muted-foreground mb-4">Bar chart</h3>
          <%= ui :chart, type: :bar,
            labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
            datasets: [
              { label: "Revenue", data: [420, 380, 510, 470, 600, 540], background_color: "oklch(0.623 0.214 259.815 / 0.7)" },
              { label: "Costs",   data: [290, 260, 340, 310, 390, 360], background_color: "oklch(0.577 0.245 27.325 / 0.7)" }
            ] %>
        </div>

        <div class="w-80">
          <h3 class="text-sm font-medium text-muted-foreground mb-4">Line chart</h3>
          <%= ui :chart, type: :line,
            labels: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
            datasets: [
              { label: "Active users", data: [120, 145, 132, 178, 195, 88, 65],
                border_color: "oklch(0.623 0.214 259.815)", background_color: "oklch(0.623 0.214 259.815 / 0.1)",
                fill: true, tension: 0.3 }
            ] %>
        </div>

        <div class="w-64">
          <h3 class="text-sm font-medium text-muted-foreground mb-4">Doughnut chart</h3>
          <%= ui :chart, type: :doughnut,
            labels: ["Ruby", "JavaScript", "CSS", "Other"],
            datasets: [
              { label: "Lines of code",
                data: [52, 28, 14, 6],
                background_color: [
                  "oklch(0.623 0.214 259.815 / 0.8)",
                  "oklch(0.769 0.188 70.08 / 0.8)",
                  "oklch(0.627 0.265 303.9 / 0.8)",
                  "oklch(0.6 0 0 / 0.5)"
                ] }
            ] %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# DEVICE MOCKUP %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Device Mockup</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
        <div class="flex justify-center">
          <div>
            <h3 class="text-sm font-medium text-muted-foreground mb-3 text-center">Phone</h3>
            <%= ui :device_mockup, variant: :phone do %>
              <div class="flex h-full items-center justify-center bg-gradient-to-br from-primary/20 to-primary/5">
                <p class="text-sm text-muted-foreground">App content</p>
              </div>
            <% end %>
          </div>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Browser</h3>
          <%= ui :device_mockup, variant: :browser, url: "https://example.com" do %>
            <div class="flex h-48 items-center justify-center bg-gradient-to-br from-primary/20 to-primary/5">
              <p class="text-sm text-muted-foreground">Browser content</p>
            </div>
          <% end %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Tablet</h3>
        <%= ui :device_mockup, variant: :tablet do %>
          <div class="flex h-full items-center justify-center bg-gradient-to-br from-primary/20 to-primary/5">
            <p class="text-sm text-muted-foreground">Tablet view</p>
          </div>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# QR CODE %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">QR Code</h2>

      <div class="flex flex-wrap gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">From image URL</h3>
          <%= ui :qr_code, src: "https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=https://github.com/alec-c4/view_primitives", alt: "GitHub repo QR code", size: 160 %>
