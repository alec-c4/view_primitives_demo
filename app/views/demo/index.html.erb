          <%= ui "indicator" do %>
            <%= ui "avatar", fallback: "Alice" %>
          <% end %>
          <%= ui "indicator", variant: :destructive do %>
            <%= ui "avatar", fallback: "Bob" %>
          <% end %>
          <%= ui "indicator", variant: :success do %>
            <%= ui "avatar", fallback: "Carol" %>
          <% end %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">With count</h3>
        <div class="flex items-center gap-6">
          <%= ui "indicator", count: 3 do %>
            <%= ui "button", "Inbox", variant: :outline %>
          <% end %>
          <%= ui "indicator", count: 99, variant: :destructive do %>
            <%= ui "button", "Notifications", variant: :outline %>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# LIST GROUP %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">List Group</h2>

      <div class="max-w-xs">
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Plain list</h3>
        <%= ui "list_group" do %>
          <%= ui "list_group_item", "Dashboard" %>
          <%= ui "list_group_item", "Settings", active: true %>
          <%= ui "list_group_item", "Billing" %>
          <%= ui "list_group_item", "Help", variant: :muted %>
        <% end %>
      </div>

      <div class="max-w-xs">
        <h3 class="text-sm font-medium text-muted-foreground mb-3">With links</h3>
        <%= ui "list_group" do %>
          <%= ui "list_group_item", "Home",     href: "/up" %>
          <%= ui "list_group_item", "Health",   href: "/up", active: true %>
          <%= ui "list_group_item", "Back",     href: "/up" %>
        <% end %>
      </div>
    </section>

