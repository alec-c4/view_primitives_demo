            <%= ui :image,
                  src: "https://placehold.co/600x300/e2e8f0/64748b?text=No+caption",
                  alt: "Figure without caption",
                  width: 600, height: 300,
                  class: "rounded-md w-full" %>
          <% end %>
        </div>
      </div>
    </section>

