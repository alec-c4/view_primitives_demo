          <p class="text-sm text-muted-foreground mb-1">0%</p>
          <%= ui "progress", value: 0 %>
        </div>
        <div>
          <p class="text-sm text-muted-foreground mb-1">33%</p>
          <%= ui "progress", value: 33 %>
        </div>
        <div>
          <p class="text-sm text-muted-foreground mb-1">75%</p>
          <%= ui "progress", value: 75 %>
        </div>
        <div>
          <p class="text-sm text-muted-foreground mb-1">100%</p>
          <%= ui "progress", value: 100 %>
        </div>
        <div>
          <p class="text-sm text-muted-foreground mb-1">3 of 10 (custom max)</p>
          <%= ui "progress", value: 3, max: 10 %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# ASPECT RATIO %>
    <%# ------------------------------------------------------------------ %>
