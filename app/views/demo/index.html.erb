              type:   "image/jpeg") %>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# IMAGE %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Image</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Basic</h3>
          <%= ui :image,
                src: "https://placehold.co/600x300/e2e8f0/64748b?text=Basic+Image",
                alt: "Basic image example",
                width: 600, height: 300,
                class: "rounded-md" %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">With srcset</h3>
          <%= ui :image,
                src: "https://placehold.co/600x300/e2e8f0/64748b?text=Image+600w",
                alt: "Responsive image with srcset",
                srcset: "https://placehold.co/300x150/e2e8f0/64748b?text=300w 300w, https://placehold.co/600x300/e2e8f0/64748b?text=600w 600w",
