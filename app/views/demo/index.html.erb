          <h3 class="text-sm font-medium text-muted-foreground mb-3">With controls</h3>
          <%= ui :video,
                poster: "https://placehold.co/640x360/e2e8f0/64748b?text=Video+poster",
                controls: true,
                class: "rounded-md w-full" do |v| %>
            <% v.with_source(src: "https://www.w3schools.com/html/mov_bbb.mp4", type: "video/mp4") %>
