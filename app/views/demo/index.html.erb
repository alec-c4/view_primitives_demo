      <h2 class="text-xl font-semibold border-b pb-2">Aspect Ratio</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">16:9 — video embed placeholder</h3>
        <div class="max-w-sm">
          <%= ui "aspect_ratio", ratio: 16.0/9 do %>
            <div class="size-full rounded-xl bg-muted flex items-center justify-center text-muted-foreground text-sm">
              16 / 9
            </div>
          <% end %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">1:1 — square image</h3>
        <div class="w-32">
          <%= ui "aspect_ratio", ratio: 1 do %>
            <div class="size-full rounded-xl bg-muted flex items-center justify-center text-muted-foreground text-sm">
              1 / 1
            </div>
          <% end %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">4:3 — classic photo</h3>
        <div class="max-w-xs">
          <%= ui "aspect_ratio", ratio: 4.0/3 do %>
            <div class="size-full rounded-xl bg-muted flex items-center justify-center text-muted-foreground text-sm">
              4 / 3
            </div>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# SPINNER %>
    <%# ------------------------------------------------------------------ %>
