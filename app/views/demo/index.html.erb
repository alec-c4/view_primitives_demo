        <h3 class="text-sm font-medium text-muted-foreground mb-3">Single keys</h3>
        <div class="flex flex-wrap items-center gap-2">
          <%= ui "kbd", "⌘" %>
          <%= ui "kbd", "K" %>
          <%= ui "kbd", "Enter" %>
          <%= ui "kbd", "Esc" %>
          <%= ui "kbd", "Tab" %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Shortcut combination</h3>
        <div class="flex items-center gap-1 text-sm text-muted-foreground">
          Press
          <%= ui "kbd", "⌘" %>
          +
          <%= ui "kbd", "K" %>
          to open the command palette.
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# RATING %>
    <%# ------------------------------------------------------------------ %>
