          <% end %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">In Aspect Ratio wrapper</h3>
          <%= ui :aspect_ratio, ratio: "16/9", class: "rounded-md overflow-hidden bg-muted" do %>
            <%= ui :video,
                  controls: true,
                  class: "h-full w-full object-cover" do |v| %>
              <% v.with_source(src: "https://www.w3schools.com/html/mov_bbb.mp4", type: "video/mp4") %>
            <% end %>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# AUDIO %>
    <%# ------------------------------------------------------------------ %>
