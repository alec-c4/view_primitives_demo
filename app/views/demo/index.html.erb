<div class="min-h-screen bg-background text-foreground">
  <div class="max-w-6xl mx-auto px-6 py-12 space-y-16">

    <header>
      <h1 class="text-3xl font-bold tracking-tight">ViewPrimitives demo</h1>
      <p class="mt-2 text-muted-foreground">Examples of every available component.</p>
    </header>

    <%# ------------------------------------------------------------------ %>
    <%# BUTTON %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-6">
      <h2 class="text-xl font-semibold border-b pb-2">Button</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Variants</h3>
        <div class="flex flex-wrap gap-3">
          <%= ui "button", "Default" %>
          <%= ui "button", "Destructive", variant: :destructive %>
          <%= ui "button", "Outline",     variant: :outline %>
          <%= ui "button", "Secondary",   variant: :secondary %>
          <%= ui "button", "Ghost",       variant: :ghost %>
          <%= ui "button", "Link",        variant: :link %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Sizes</h3>
        <div class="flex flex-wrap items-center gap-3">
          <%= ui "button", "Small",   size: :sm %>
          <%= ui "button", "Default", size: :default %>
          <%= ui "button", "Large",   size: :lg %>
          <%= ui "button", size: :icon do %>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          <% end %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">As link (href:)</h3>
        <div class="flex flex-wrap gap-3">
          <%= ui "button", "Go to /up", href: "/up", variant: :outline %>
          <%= ui "button", "Ghost link", href: "/up", variant: :ghost %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">label: keyword</h3>
        <div class="flex flex-wrap gap-3">
          <%= ui "button", label: "Keyword label" %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Disabled</h3>
        <div class="flex flex-wrap gap-3">
          <%= ui "button", "Disabled", disabled: true %>
          <%= ui "button", "Disabled outline", variant: :outline, disabled: true %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# ALERT %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Alert</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">kwargs (plain text)</h3>
        <%= ui "alert", title: "Heads up!", description: "You can change this in your account settings." %>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Destructive variant</h3>
        <%= ui "alert", variant: :destructive,
                        title: "Error",
                        description: "Your session has expired. Please log in again." %>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Title only</h3>
        <%= ui "alert", title: "Maintenance scheduled for Sunday 02:00 UTC." %>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">With icon</h3>
        <%= ui "alert", variant: :destructive do |alert| %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/>
            <line x1="12" x2="12.01" y1="16" y2="16"/>
          </svg>
          <% alert.with_alert_title { "Something went wrong" } %>
          <% alert.with_alert_description { "Please try again or contact support." } %>
        <% end %>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Rich description via slot</h3>
        <%= ui "alert", title: "Action required" do |alert| %>
          <% alert.with_alert_description do %>
            Please review the
            <a href="/up" class="font-medium underline underline-offset-4">terms of service</a>
            before continuing.
          <% end %>
        <% end %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# ACCORDION %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-6">
      <h2 class="text-xl font-semibold border-b pb-2">Accordion</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Default (multiple open)</h3>
        <%= ui "accordion", items: [
          { title: "What is ViewPrimitives?",
            content: "A shadcn/ui-inspired component library for Rails built on ViewComponent. Components are copied into your app via a generator." },
          { title: "Do I need to configure Tailwind?",
            content: "No configuration needed. The @theme inline block in view_primitives.css registers all design tokens automatically." },
          { title: "Can I customise the components?",
            content: "Yes — the files live in app/components/ui/ and are yours to edit freely." }
        ] %>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Open by default + slot API</h3>
        <%= ui "accordion" do |accordion| %>
          <% accordion.with_item(title: "This item is open by default", open: true) do %>
            Content that is visible immediately on page load without any interaction.
          <% end %>
          <% accordion.with_item(title: "Rich content via slot") do %>
            <ul class="list-disc pl-4 space-y-1 text-muted-foreground">
              <li>Items can contain any HTML</li>
              <li>Links, <strong>bold text</strong>, anything goes</li>
              <li>Use slots for complex content, <code class="bg-muted px-1 rounded text-xs">items:</code> for plain text</li>
            </ul>
          <% end %>
          <% accordion.with_item(title: "Custom class on details element") do %>
            This item passes <code class="bg-muted px-1 rounded text-xs">class: "border-b border-dashed group"</code>
            to override the default border style.
          <% end %>
        <% end %>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">exclusive: true (only one open at a time)</h3>
        <%= ui "accordion", exclusive: true, items: [
          { title: "Opening this closes the others",
            content: "Try opening another item — this one will close automatically." },
          { title: "Second item",
            content: "Powered by a Stimulus controller. No page reload, no Turbo frames." },
          { title: "Third item",
            content: "Works the same with the slot API — just pass exclusive: true to the AccordionComponent." }
        ] %>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">exclusive: true + slot API</h3>
        <%= ui "accordion", exclusive: true do |accordion| %>
          <% accordion.with_item(title: "Slot item one") do %>
            Rich HTML content works too. <strong>Bold</strong>, <em>italic</em>, anything.
          <% end %>
          <% accordion.with_item(title: "Slot item two", open: true) do %>
            This item starts open. Opening another will close it.
          <% end %>
          <% accordion.with_item(title: "Slot item three") do %>
            The Stimulus controller listens for clicks on the wrapper and closes all
            <code class="bg-muted px-1 rounded text-xs">details[open]</code> siblings
            before the browser processes the toggle.
          <% end %>
        <% end %>
      </div>
    </section>


    <%# ================================================================== %>
    <%# PHASE 3 — FORMS %>
    <%# ================================================================== %>

    <%# ------------------------------------------------------------------ %>
    <%# INPUT %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Input</h2>

      <div class="max-w-sm space-y-3">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Text</h3>
          <%= ui "input", placeholder: "Email address" %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Password</h3>
          <%= ui "input", type: "password", placeholder: "Password" %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Disabled</h3>
          <%= ui "input", placeholder: "Can't touch this", disabled: true %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">With value</h3>
          <%= ui "input", value: "alice@example.com" %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# TEXTAREA %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Textarea</h2>

      <div class="max-w-sm space-y-3">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Default</h3>
          <%= ui "textarea", placeholder: "Write something..." %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Taller</h3>
          <%= ui "textarea", placeholder: "Longer content...", class: "min-h-[160px]" %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Disabled</h3>
          <%= ui "textarea", placeholder: "Read only", disabled: true %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# CHECKBOX %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Checkbox</h2>

      <div class="space-y-3">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">With label</h3>
          <%= ui "checkbox", label: "Accept terms and conditions", name: "terms", id: "terms" %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Pre-checked</h3>
          <%= ui "checkbox", label: "Subscribe to newsletter", name: "newsletter", checked: true %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Without label (standalone)</h3>
          <%= ui "checkbox", name: "standalone" %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# RADIO GROUP %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Radio Group</h2>

      <div class="space-y-3">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Default</h3>
          <%= ui "radio_group", name: "plan", items: [
            { value: "free",    label: "Free" },
            { value: "pro",     label: "Pro" },
            { value: "team",    label: "Team", checked: true }
          ] %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# SELECT %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Select</h2>

      <div class="max-w-sm space-y-3">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Array of strings</h3>
          <%= ui "select", options: %w[Apple Banana Cherry], name: "fruit" %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Value/label pairs</h3>
          <%= ui "select",
            options: [["us", "United States"], ["gb", "United Kingdom"], ["de", "Germany"]],
            selected: "gb",
            name: "country" %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">With blank option</h3>
          <%= ui "select",
            options: %w[Design Engineering Marketing],
            include_blank: true,
            name: "department" %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# SWITCH %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Switch</h2>

      <div class="space-y-3">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Off (default)</h3>
          <%= ui "switch", label: "Dark mode", name: "dark_mode" %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">On</h3>
          <%= ui "switch", label: "Notifications enabled", name: "notifications", checked: true %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Without label</h3>
          <%= ui "switch", name: "silent" %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# TOGGLE %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Toggle</h2>

      <div class="space-y-3">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Default (not pressed)</h3>
          <div class="flex gap-2">
            <%= ui "toggle", "Bold" %>
            <%= ui "toggle", "Italic", pressed: true %>
            <%= ui "toggle", "Underline" %>
          </div>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Sizes</h3>
          <div class="flex items-center gap-2">
            <%= ui "toggle", "Sm", size: :sm %>
            <%= ui "toggle", "Default" %>
            <%= ui "toggle", "Lg", size: :lg %>
          </div>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">With icon</h3>
          <%= ui "toggle" do %>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/>
            </svg>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# TOGGLE GROUP %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Toggle Group</h2>

      <div class="space-y-3">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Single selection</h3>
          <%= ui "toggle_group", type: :single, value: "center" do %>
            <%= ui "toggle", "Left",   value: "left" %>
            <%= ui "toggle", "Center", value: "center", pressed: true %>
            <%= ui "toggle", "Right",  value: "right" %>
          <% end %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Multiple selection</h3>
          <%= ui "toggle_group", type: :multiple, value: ["bold", "underline"] do %>
            <%= ui "toggle", "Bold",      value: "bold",      pressed: true %>
            <%= ui "toggle", "Italic",    value: "italic" %>
            <%= ui "toggle", "Underline", value: "underline", pressed: true %>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# FORM FIELD %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Form Field</h2>

      <div class="max-w-sm space-y-4">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Label + hint</h3>
          <%= ui "form_field", label: "Username", hint: "Letters and numbers only." do %>
            <%= ui "input", name: "username", placeholder: "alice" %>
          <% end %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Required</h3>
          <%= ui "form_field", label: "Email", required: true do %>
            <%= ui "input", type: "email", name: "email", placeholder: "you@example.com" %>
          <% end %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">With validation error</h3>
          <%= ui "form_field", label: "Password", error: "is too short (minimum 8 characters)" do %>
            <%= ui "input", type: "password", name: "password", class: "border-destructive focus-visible:ring-destructive" %>
          <% end %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Complete form example</h3>
          <%= form_with url: "/up", method: :post, class: "space-y-4" do %>
            <%= ui "form_field", label: "Full name", required: true do %>
              <%= ui "input", name: "name", placeholder: "Alice Smith" %>
            <% end %>
            <%= ui "form_field", label: "Bio", hint: "Max 200 characters." do %>
              <%= ui "textarea", name: "bio", placeholder: "Tell us about yourself..." %>
            <% end %>
            <%= ui "form_field", label: "Country" do %>
              <%= ui "select", options: [["us", "United States"], ["gb", "United Kingdom"]], name: "country" %>
            <% end %>
            <%= ui "checkbox", label: "I agree to the terms", name: "terms" %>
            <div class="flex gap-2">
              <%= ui "button", "Save", type: "submit" %>
              <%= ui "button", "Cancel", variant: :outline %>
            </div>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# FILE INPUT %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">File Input</h2>
      <div class="flex flex-wrap gap-6 max-w-lg">
        <div class="w-full">
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Single file</h3>
          <%= ui :file_input, name: "avatar" %>
        </div>
        <div class="w-full">
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Multiple images</h3>
          <%= ui :file_input, name: "photos[]", multiple: true, accept: "image/*" %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# SEARCH INPUT %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Search Input</h2>
      <div class="max-w-sm space-y-3">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Default</h3>
          <%= ui :search_input, name: "q" %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Custom placeholder</h3>
          <%= ui :search_input, name: "q", placeholder: "Search components…" %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# NUMBER INPUT %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Number Input</h2>
      <div class="flex flex-wrap gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Default</h3>
          <%= ui :number_input, name: "qty", value: 1 %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">With min/max/step</h3>
          <%= ui :number_input, name: "age", value: 18, min: 0, max: 120, step: 1 %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# RANGE %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Range</h2>
      <div class="max-w-sm space-y-4">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Default (0–100)</h3>
          <%= ui :range, name: "volume", value: 40 %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Custom step</h3>
          <%= ui :range, name: "opacity", min: 0, max: 1, step: 0.1, value: 0.7 %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# FLOATING LABEL %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Floating Label</h2>
      <div class="flex flex-wrap gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Text</h3>
          <%= ui :floating_label, label: "Full name", id: "fl_name", name: "name" %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Email</h3>
          <%= ui :floating_label, label: "Email address", type: "email", id: "fl_email", name: "email" %>
        </div>
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-2">Password</h3>
          <%= ui :floating_label, label: "Password", type: "password", id: "fl_pass", name: "password" %>
        </div>
      </div>
    </section>

    <%# ================================================================== %>
    <%# PHASE 2 — DISPLAY %>
    <%# ================================================================== %>

    <%# ------------------------------------------------------------------ %>
    <%# BADGE %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Badge</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Variants</h3>
        <div class="flex flex-wrap gap-3">
          <%= ui "badge", "Default" %>
          <%= ui "badge", "Secondary",   variant: :secondary %>
          <%= ui "badge", "Destructive", variant: :destructive %>
          <%= ui "badge", "Outline",     variant: :outline %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">label: keyword + block</h3>
        <div class="flex flex-wrap gap-3">
          <%= ui "badge", label: "Keyword" %>
          <%= ui "badge", variant: :secondary do %>Block content<% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# AVATAR %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Avatar</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">With image</h3>
        <div class="flex flex-wrap items-center gap-4">
          <%= ui "avatar", src: "https://i.pravatar.cc/48?img=1", alt: "Alice", size: :sm %>
          <%= ui "avatar", src: "https://i.pravatar.cc/48?img=2", alt: "Bob" %>
          <%= ui "avatar", src: "https://i.pravatar.cc/48?img=3", alt: "Carol", size: :lg %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Initials fallback</h3>
        <div class="flex flex-wrap items-center gap-4">
          <%= ui "avatar", fallback: "Jane Doe", size: :sm %>
          <%= ui "avatar", fallback: "John Smith" %>
          <%= ui "avatar", alt: "Alex Kim", size: :lg %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# CARD %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Card</h2>

      <div class="max-w-sm">
        <%= ui "card" do %>
          <%= ui "card_header" do %>
            <%= ui "card_title", "Create project" %>
            <%= ui "card_description", "Deploy your new project in one click." %>
          <% end %>
          <%= ui "card_content" do %>
            <p class="text-sm text-muted-foreground">Your project will be deployed using the default configuration.</p>
          <% end %>
          <%= ui "card_footer" do %>
