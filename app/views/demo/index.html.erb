        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# FIGURE %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Figure</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">With caption</h3>
          <%= ui :figure, caption: "Figure 1 — A placeholder image used for illustration." do %>
            <%= ui :image,
                  src: "https://placehold.co/600x300/e2e8f0/64748b?text=Figure+content",
