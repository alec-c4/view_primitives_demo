      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Last page (next disabled)</h3>
        <%= ui :pagination,
              current_page: 8,
              total_pages: 8,
              url: ->(page) { "/?page=#{page}" } %>
