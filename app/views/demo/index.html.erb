            <div class="space-y-1">
              <p class="text-sm text-muted-foreground">How would you rate this component?</p>
              <%= ui "rating_input", value: 0, name: "review[rating]" %>
            </div>
            <%= ui "button", "Submit", type: "submit", size: :sm %>
          <% end %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Custom max</h3>
        <%= ui "rating_input", value: 6, max: 10 %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# INDICATOR %>
    <%# ------------------------------------------------------------------ %>
