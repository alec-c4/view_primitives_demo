          <% end %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Looping</h3>
          <%= ui :audio, controls: true, loop: true, class: "w-full" do |a| %>
            <% a.with_source(src: "https://www.w3schools.com/html/horse.mp3", type: "audio/mpeg") %>
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# IFRAME %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Iframe</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Fixed height</h3>
          <%= ui :iframe,
                src: "https://www.openstreetmap.org/export/embed.html?bbox=-0.2,51.4,0.0,51.6&layer=mapnik",
                title: "OpenStreetMap — London area",
                height: 300,
                class: "rounded-md" %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">16:9 aspect ratio</h3>
          <%= ui :iframe,
                src: "https://www.youtube.com/embed/dQw4w9WgXcQ",
                title: "YouTube video embed example",
                aspect: "16/9",
                class: "rounded-md" %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# WYSIWYG %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">WYSIWYG</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Trix (default)</h3>
        <%= ui :wysiwyg, name: "body_trix",
              placeholder: "Write something with Trix..." %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Quill</h3>
          <%= ui :wysiwyg, name: "body_quill", adapter: :quill,
                placeholder: "Write something with Quill...",
                height: 180 %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Quill without toolbar</h3>
          <%= ui :wysiwyg, name: "notes", adapter: :quill,
                placeholder: "Plain text area, no toolbar...",
                toolbar: false,
                height: 180 %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# MAP AREA %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Map / Area</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Clickable regions on an image</h3>
        <%= ui :map_area,
              src: "https://placehold.co/800x400/e2e8f0/64748b?text=Image+Map+(click+the+regions)",
              alt: "Image map demo",
              width: 800, height: 400,
              areas: [
                { shape: :rect,   coords: "0,0,266,400",   href: "#left",   alt: "Left region",   title: "Left region" },
                { shape: :rect,   coords: "267,0,533,400",  href: "#center", alt: "Center region", title: "Center region" },
                { shape: :rect,   coords: "534,0,800,400",  href: "#right",  alt: "Right region",  title: "Right region" }
              ],
              class: "rounded-md overflow-hidden" %>
        <p class="mt-2 text-xs text-muted-foreground">Three equal clickable columns — inspect the element to see the <code>&lt;map&gt;</code> structure.</p>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Circle and polygon areas</h3>
        <%= ui :map_area,
              src: "https://placehold.co/600x300/e2e8f0/64748b?text=Circle+%26+Poly+regions",
              alt: "Circle and polygon image map demo",
              width: 600, height: 300,
              areas: [
                { shape: :circle, coords: "150,150,100",               href: "#circle", alt: "Circle area",   title: "Circle" },
                { shape: :poly,   coords: "400,50,550,50,575,250,375,250", href: "#poly",   alt: "Polygon area", title: "Polygon" }
              ],
              class: "rounded-md overflow-hidden" %>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# EMBED %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Embed</h2>

      <%# Auto-detect from URL — no type: needed %>
      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Auto-detect from URL</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <p class="text-xs text-muted-foreground mb-2 font-mono">url: "https://youtu.be/dQw4w9WgXcQ"</p>
            <%= ui :embed, url: "https://youtu.be/dQw4w9WgXcQ" %>
          </div>
          <div>
            <p class="text-xs text-muted-foreground mb-2 font-mono">url: "https://vimeo.com/148751763"</p>
            <%= ui :embed, url: "https://vimeo.com/148751763" %>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Spotify — track</h3>
          <%= ui :embed, url: "https://open.spotify.com/track/4iV5W9uYEdYUVa79Axb7Rh" %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Spotify — playlist (full height)</h3>
          <%= ui :embed, url: "https://open.spotify.com/playlist/37i9dQZF1DXcBWIGoYBM5M", height: 380 %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Google Maps — query</h3>
          <%= ui :embed, query: "Eiffel Tower, Paris" %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Yandex Maps</h3>
          <%= ui :embed, url: "https://yandex.ru/maps/213/moscow/?ll=37.617685,55.755814&z=10" %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">SoundCloud</h3>
        <%= ui :embed, url: "https://soundcloud.com/forss/flickermood" %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">X — официальный виджет</h3>
          <%= ui :embed, url: "https://x.com/jack/status/20" %>
        </div>

        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Telegram — официальный виджет</h3>
          <%= ui :embed, url: "https://t.me/telegram/193" %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Facebook video</h3>
        <%= ui :embed, url: "https://www.facebook.com/watch/?v=1234567890",
              class: "max-w-xl" %>
      </div>
    </section>

  </div>
</div>
