      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Sizes</h3>
        <div class="flex items-center gap-6">
          <%= ui "spinner", size: :sm %>
          <%= ui "spinner" %>
          <%= ui "spinner", size: :lg %>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">With button (loading state)</h3>
        <div class="flex items-center gap-3">
          <%= ui "button", variant: :outline, disabled: true do %>
            <%= ui "spinner", size: :sm, class: "mr-2" %>
            Saving…
          <% end %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# KBD %>
    <%# ------------------------------------------------------------------ %>
