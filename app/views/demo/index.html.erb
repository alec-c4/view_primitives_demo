          { label: "Processing",    description: "Your order is being packed.",  status: :current  },
          { label: "Shipped",       description: "On its way to you.",           status: :pending  },
          { label: "Delivered",     description: "Enjoy!",                       status: :pending  }
        ] %>
      </div>
