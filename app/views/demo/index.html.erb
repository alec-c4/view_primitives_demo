      <h2 class="text-xl font-semibold border-b pb-2">Audio</h2>

      <div class="space-y-4">
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">With controls</h3>
          <%= ui :audio, controls: true, class: "w-full" do |a| %>
            <% a.with_source(src: "https://www.w3schools.com/html/horse.ogg", type: "audio/ogg") %>
            <% a.with_source(src: "https://www.w3schools.com/html/horse.mp3", type: "audio/mpeg") %>
