          <h3 class="text-sm font-medium text-muted-foreground mb-3">Custom size</h3>
          <%= ui :qr_code, src: "https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=https://example.com", alt: "Example.com QR code", size: 120 %>
        </div>
      </div>
    </section>

    <%# ------------------------------------------------------------------ %>
    <%# PICTURE %>
    <%# ------------------------------------------------------------------ %>
    <section class="space-y-4">
      <h2 class="text-xl font-semibold border-b pb-2">Picture</h2>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Art direction with sources</h3>
        <%= ui :picture,
              src: "https://placehold.co/800x400/e2e8f0/64748b?text=Fallback+800x400",
              alt: "Responsive demo image",
              width: 800, height: 400 do |p| %>
          <% p.with_source(
