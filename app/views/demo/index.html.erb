      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Default buttons</h3>
        <%= ui "button_group" do %>
          <%= ui "button", "Previous", variant: :outline %>
          <%= ui "button", "Current",  variant: :outline %>
          <%= ui "button", "Next",     variant: :outline %>
        <% end %>
      </div>

      <div>
        <h3 class="text-sm font-medium text-muted-foreground mb-3">Mixed variants</h3>
        <%= ui "button_group" do %>
          <%= ui "button", "Copy",    variant: :secondary %>
          <%= ui "button", "Paste",   variant: :secondary %>
          <%= ui "button", "Delete",  variant: :destructive %>
        <% end %>
      </div>
